NODE_ENV=production
PORT=4000
CLIENT_ORIGIN=https://spakstrip.com

MONGO_URI=<YOUR_MONGO_URI>
ACCESS_TOKEN_SECRET=<YOUR_ACCESS_TOKEN_SECRET>
REFRESH_TOKEN_SECRET=<YOUR_REFRESH_TOKEN_SECRET>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
SUPERADMIN_PASSWORD=<YOUR_SUPERADMIN_PASSWORD>
# Cloudinary (partner listing image/document uploads). Set either CLOUDINARY_URL
# or the three discrete vars below.
CLOUDINARY_URL=cloudinary://<YOUR_CLOUDINARY_API_KEY>:<YOUR_CLOUDINARY_API_SECRET>@<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_API_KEY=<YOUR_CLOUDINARY_API_KEY>
CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>
APEX_DOMAIN=http://localhost:3000

# ── PostgreSQL transaction ledger (additive — alongside MongoDB) ──────────────
# Leave DATABASE_URL empty to run in MongoDB-only mode (server still boots).
# Supabase Session pooler (IPv4). Percent-encode special characters in the password.
DATABASE_URL=<YOUR_POSTGRES_DATABASE_URL>
# Pool size override (optional)
# PG_POOL_MAX=10



# ── Background worker intervals (ms) — heal 5m / reconcile 60m / DLQ 10m ───────
HEAL_WORKER_INTERVAL_MS=300000
RECONCILIATION_WORKER_INTERVAL_MS=3600000
DLQ_WORKER_INTERVAL_MS=600000


# ── TBO Air API — PRODUCTION endpoints ────────────────────────────────────────
# Three hosts: Shared (auth) / Air search / Booking. Flip cert↔prod by these vars only.
#   Shared (Authenticate)
TBO_SHARED_API_URL=https://api.travelboutiqueonline.com/SharedAPI
#   Air search host: Search, FareRule, FareQuote, SSR, Calendar Fare, Price RBD
TBO_AIR_API_URL=https://tboapi.travelboutiqueonline.com
#   Booking host: Book, Ticket, GetBookingDetails, Send/GetChangeRequest, ReleasePNR
TBO_BOOK_API_URL=https://booking.travelboutiqueonline.com
# Legacy base (hotel fallback derivation only; air/book/shared use the explicit vars above)
TBO_API_URL=http://api.tektravels.com
# ClientId issued by TBO for the production environment (cert default is ApiIntegrationNew).
# Read in auth.ts via process.env.TBO_CLIENT_ID — set the live value here.
# LIVE Flight API creds — distinct from the TBO Holidays hotel account below;
# do not conflate the two.
TBO_CLIENT_ID=<YOUR_TBO_CLIENT_ID>
TBO_AIR_USERNAME=<YOUR_TBO_AIR_USERNAME>
TBO_AIR_PASSWORD=<YOUR_TBO_AIR_PASSWORD>
TBO_END_USER_IP=1.1.1.1
# TBOHolidays static data APIs (CountryList, CityList, HotelDetails, HotelCodes, TBOHotelCodeList)
# These are the shared public test credentials documented by TBO.
TBO_HOLIDAYS_STATIC_USER_NAME=TBOStaticAPITest
TBO_HOLIDAYS_STATIC_PASSWORD=Tbo@11530818

# TBOHolidays booking APIs (HotelSearch, PreBook, Book)
# Use the agency credentials TBO provided during your agency account creation.
TBO_HOLIDAYS_USER_NAME=<YOUR_TBO_HOLIDAYS_USER_NAME>
TBO_HOLIDAYS_PASSWORD=<YOUR_TBO_HOLIDAYS_PASSWORD>
# Base URL for TBOHolidays Search and PreBook
TBO_HOLIDAYS_SEARCH_URL=https://affiliate.tektravels.com/HotelAPI
# Base URL for TBOHolidays Book (different host per TBO docs)
TBO_HOLIDAYS_BOOK_URL=https://HotelBE.tektravels.com/hotelservice.svc/rest/book
# Base URL for TBOHolidays GetBookingDetail
TBO_HOLIDAYS_BOOKING_URL=https://hotelbe.tektravels.com/hotelservice.svc/rest/Getbookingdetail
# Base URL for TBOHolidays static data endpoints (CountryList, CityList, etc.)
TBO_HOLIDAYS_HOTEL_API_URL=https://api.tbotechnology.in/TBOHolidays_HotelAPI
INTERNATIONAL_CHILDREN_CITY_CODE=144092
# Enable TBO debug logging
TBO_DEBUG=true


# ── Razorpay payments ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=<YOUR_RAZORPAY_KEY_ID>
NEXT_PUBLIC_RAZORPAY_KEY_ID=<YOUR_RAZORPAY_KEY_ID>
RAZORPAY_KEY_SECRET=<YOUR_RAZORPAY_KEY_SECRET>

# mailer creds
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=<YOUR_EMAIL_ADDRESS>
# EMAIL_PASS=<YOUR_EMAIL_APP_PASSWORD>
# EMAIL_FROM=SpaksTrip <YOUR_EMAIL_ADDRESS>

EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=<YOUR_EMAIL_ADDRESS>        # full mailbox address
EMAIL_PASS=<YOUR_EMAIL_PASSWORD>        # the real password, not an app-password
EMAIL_FROM=SpaksTrip <YOUR_EMAIL_ADDRESS>


# twilio creds
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
