# ══════════════════════════════════════════════════════════════════════════════
# SpaksTrip — Express API (server/) environment reference
# Copy to .env and fill in real values. Never commit .env.
#
# Enumerated from every `process.env.*` read in server/src + server/scripts.
# REQUIRED vars are validated at startup by src/config/env.ts (zod) — the
# server refuses to boot and names the missing/malformed var.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Browser origin allowed by CORS (the Next.js app).
CLIENT_ORIGIN=http://localhost:3000

# ── MongoDB (REQUIRED — MONGO_URI or legacy alias MONGODB_URI) ────────────────
MONGO_URI=mongodb://localhost:27017/spakstrip

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=change_me_long_random_string
REFRESH_TOKEN_SECRET=change_me_other_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# Minutes of inactivity before an idle session is revoked (optional).
IDLE_SESSION_TIMEOUT_MIN=
# Bump to force re-consent of T&C/privacy (optional).
CONSENT_VERSION=

# ── Superadmin panel ──────────────────────────────────────────────────────────
# Recipient for "new pending registration" notifications.
SUPERADMIN_EMAIL=admin@spakstrip.local
# Env password gate for /superadmin (empty = admin login disabled).
SUPERADMIN_PASSWORD=
# Secret for the admin-session cookie (falls back to ACCESS_TOKEN_SECRET).
ADMIN_SESSION_SECRET=

# ── Cloudinary (partner listing uploads) ──────────────────────────────────────
# Either the single URL or the three discrete vars.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PostgreSQL financial ledger (additive; empty = MongoDB-only mode) ─────────
DATABASE_URL=
PG_POOL_MAX=10

# ── Razorpay payments ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Pricing token (must match the Next.js app's PRICE_TOKEN_SECRET) ───────────
PRICE_TOKEN_SECRET=

# ── Internal API secret (must match the Next.js app's INTERNAL_API_SECRET) ────
# Gates /api/internal/* (agent-config, record-booking, …). Unset = no gate
# (existing behavior). Set the SAME value on both apps to close the gap.
INTERNAL_API_SECRET=

# ── Agent-config cache tuning (server/src/lib/agentCache.ts) — optional ───────
AGENT_CACHE_SOFT_TTL_MS=20000
AGENT_CACHE_HARD_TTL_MS=300000
AGENT_CACHE_MAX_ENTRIES=5000

# ── SMTP (transactional email; unset EMAIL_HOST = console logging) ────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=SpaksTrip <no-reply@spakstrip.com>

# ── TBO Air API (flights via Express egress proxy) ────────────────────────────
TBO_CLIENT_ID=ApiIntegrationNew
TBO_AIR_USERNAME=your_username
TBO_END_USER_IP=1.1.1.1
TBO_AGENCY_ID=
TBO_DEBUG=false

# ── Background workers (intervals in ms) ──────────────────────────────────────
HEAL_WORKER_INTERVAL_MS=300000
RECONCILIATION_WORKER_INTERVAL_MS=3600000
DLQ_WORKER_INTERVAL_MS=600000

# ── Events module ─────────────────────────────────────────────────────────────
EVENT_BOOKING_HOLD_MINUTES=10
EVENT_PLATFORM_FEE_PERCENT=5
EVENT_GST_PERCENT=18
EVENT_REMINDERS_ENABLED=false
EVENT_REMINDER_INTERVAL_MS=3600000
EVENT_REMINDER_LEAD_HOURS=24

# ── External event discovery (all OFF by default) ─────────────────────────────
TICKETMASTER_ENABLED=false
TICKETMASTER_API_KEY=
INSIDER_API_ENABLED=false
INSIDER_API_KEY=
BOOKMYSHOW_AFFILIATE_ENABLED=false
BOOKMYSHOW_AFFILIATE_ID=
EXTERNAL_EVENTS_SYNC_ENABLED=false
EXTERNAL_EVENTS_SYNC_INTERVAL_MS=21600000
EXTERNAL_EVENTS_CACHE_TTL_HOURS=24
EXTERNAL_EVENTS_SYNC_CITIES=delhi,mumbai,bangalore,hyderabad,chennai,kolkata,pune,ahmedabad,jaipur,goa

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
