{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:dev": "tsx --env-file=.env scripts/seed-dev-users.ts",
    "seed:demo": "tsx --env-file=.env scripts/seed-demo-partner.ts",
    "smoke:events": "tsx --env-file=.env scripts/events-smoke.ts",
    "generate:slugs": "tsx --env-file=.env scripts/generate-agent-slugs.ts",
    "update:airports": "tsx --env-file=.env scripts/updateAirportData.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "axios": "^1.15.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.0",
    "opossum": "^9.0.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
